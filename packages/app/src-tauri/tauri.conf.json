{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "auth-scenario",
  "version": "0.1.0",
  "identifier": "com.auth-scenario.app",
  "build": {
    "beforeDevCommand": "pnpm vite:dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm vite build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "auth-scenario",
        "width": 1200,
        "height": 800
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": {
      "../../lib/src/": "lib/src/"
    }
  }
}
