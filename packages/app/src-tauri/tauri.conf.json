{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "YML 2 Puppeteer",
  "version": "0.2.0-rc.0",
  "identifier": "com.yml2puppeteerauth.app",
  "build": {
    "beforeDevCommand": "pnpm vite:dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm --filter yml-2-puppeteer-auth bundle && pnpm vite build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "YML 2 Puppeteer",
        "width": 1200,
        "height": 800
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "../../lib/dist/cli.bundle.cjs": "cli.bundle.cjs"
    }
  }
}
